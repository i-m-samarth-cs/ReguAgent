# Database (Use postgresql://... for Docker/production, sqlite:///reguagent.db for simple local dev)
DATABASE_URL=sqlite:///reguagent.db

# Redis (Only needed if CELERY_ALWAYS_EAGER=false)
REDIS_URL=redis://localhost:6379/0

# Celery (Set to true to run tasks synchronously inside the FastAPI process, no Celery worker or Redis required)
CELERY_ALWAYS_EAGER=true

# Auth
SECRET_KEY=super_secret_key_for_demo_only_change_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider (mock | openai | anthropic)
AI_MODE=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
